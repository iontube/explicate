---
const currentPath = Astro.url.pathname;

const mainNav = [
  { href: '/matematica/', label: 'Matematică' },
  { href: '/romana/', label: 'Română' },
  { href: '/fizica/', label: 'Fizică' },
  { href: '/chimie/', label: 'Chimie' },
  { href: '/biologie/', label: 'Biologie' },
  { href: '/istorie/', label: 'Istorie' },
];

const moreNav = [
  { href: '/geografie/', label: 'Geografie' },
  { href: '/informatica/', label: 'Informatică' },
  { href: '/educatie-civica/', label: 'Ed. Civică' },
  { href: '/filosofie/', label: 'Filosofie' },
  { href: '/economie/', label: 'Economie' },
  { href: '/engleza/', label: 'Engleză' },
];

const allNav = [...mainNav, ...moreNav];
---

<header class="border-b border-gray-200 bg-white">
  <div class="wrap">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="no-underline shrink-0">
        <img src="/logo.svg" alt="explicate.ro" class="h-10 w-auto" width="250" height="50" loading="eager" />
      </a>

      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Materii">
        {mainNav.map(link => (
          <a href={link.href} class:list={[
            'px-2.5 py-1.5 rounded-md text-sm font-medium no-underline transition-colors',
            currentPath.startsWith(link.href) ? 'bg-pri-50 text-pri-700' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50',
          ]}>{link.label}</a>
        ))}
        <details class="relative">
          <summary class="px-2.5 py-1.5 rounded-md text-sm font-medium text-gray-500 hover:text-gray-900 hover:bg-gray-50 cursor-pointer list-none select-none">
            Mai multe ▾
          </summary>
          <div class="absolute right-0 top-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg py-1 z-50 min-w-[160px]">
            {moreNav.map(link => (
              <a href={link.href} class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 no-underline">{link.label}</a>
            ))}
          </div>
        </details>
      </nav>

      <button id="menu-btn" type="button" class="lg:hidden p-2 -mr-2 text-gray-400 hover:text-gray-700" aria-label="Meniu">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100">
    <nav class="wrap py-3 flex flex-col gap-0.5">
      {allNav.map(link => (
        <a href={link.href} class:list={[
          'px-3 py-2 rounded-md text-sm font-medium no-underline',
          currentPath.startsWith(link.href) ? 'bg-pri-50 text-pri-700' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50',
        ]}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
