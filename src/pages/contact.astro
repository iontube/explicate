---
import Layout from '../layouts/Layout.astro';
import SEOHead from '../components/SEOHead.astro';
---

<Layout>
  <SEOHead slot="head" title="Contact" description="Contactează echipa explicate.ro." canonical="/contact/" />
  <div class="wrap-sm py-8">
    <h1 class="text-2xl font-display font-bold text-gray-900 mb-6">Contact</h1>
    <div class="content">
      <p>Pentru întrebări sau sugestii: <strong>contact@explicate.ro</strong></p>
      <p>Informațiile de pe acest site sunt în scop educativ și nu înlocuiesc manualele școlare sau consultarea unui profesor.</p>
    </div>
  </div>
</Layout>
